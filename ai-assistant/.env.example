# Local development only. These values are placeholders, not production secrets.
# The fake provider (default) needs none of this - see docs/ai-operations-assistant.md.

AI_ASSISTANT_PROVIDER=fake

# Only read when AI_ASSISTANT_PROVIDER=openai. Never commit a real key.
AI_ASSISTANT_OPENAI_API_KEY=
AI_ASSISTANT_OPENAI_MODEL=gpt-5.6-luna

AI_ASSISTANT_MAX_OUTPUT_TOKENS=800
AI_ASSISTANT_TIMEOUT_SECONDS=20
AI_ASSISTANT_MAX_TELEMETRY_CHARS=4000
AI_ASSISTANT_MAX_COST_USD_PER_REQUEST=0.05
