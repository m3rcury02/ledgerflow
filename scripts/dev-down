#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
ENV_FILE=${LEDGERFLOW_ENV_FILE:-"$ROOT_DIR/.env"}

if [[ ! -f "$ENV_FILE" ]]; then
  ENV_FILE="$ROOT_DIR/.env.example"
fi

docker compose \
  --env-file "$ENV_FILE" \
  --file "$ROOT_DIR/compose.yaml" \
  down \
  --remove-orphans
