#!/usr/bin/env bash
# Builds the application's own container image and generates an SBOM plus a Trivy
# vulnerability scan for it locally — the CI equivalent of .github/workflows/ci.yml's
# "Build and scan OCI image" job, for use outside CI. Complements scripts/security-scan,
# which scans the Compose dependency images and the packaged Java artifact but not this
# image itself. Uses the exact same pinned Trivy image scripts/security-scan uses.
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
TRIVY_IMAGE='ghcr.io/aquasecurity/trivy:0.72.0@sha256:cffe3f5161a47a6823fbd23d985795b3ed72a4c806da4c4df16266c02accdd6f'
SYFT_IMAGE='anchore/syft:v1.48.0@sha256:b4f1df79f97b817682d8b5ff941eb6bfe74f6172553a5e312c75bbc2eabc405c'
TRIVY_CACHE_VOLUME=${LEDGERFLOW_TRIVY_CACHE_VOLUME:-ledgerflow-trivy-cache}
IMAGE_TAG=${IMAGE_TAG:-ledgerflow:scan-local}
OUTPUT_DIR=${OUTPUT_DIR:-"$ROOT_DIR/build/image-scan"}

mkdir -p "$OUTPUT_DIR"
docker info >/dev/null

echo "Building $IMAGE_TAG"
docker build \
  --build-arg "IMAGE_REVISION=$(git -C "$ROOT_DIR" rev-parse HEAD 2>/dev/null || echo unknown)" \
  --build-arg "IMAGE_CREATED=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
  --tag "$IMAGE_TAG" \
  "$ROOT_DIR"

echo "Generating a CycloneDX SBOM: $OUTPUT_DIR/sbom.cyclonedx.json"
docker run --rm \
  --volume /var/run/docker.sock:/var/run/docker.sock:ro \
  --volume "$OUTPUT_DIR:/out" \
  "$SYFT_IMAGE" \
  "$IMAGE_TAG" \
  --output "cyclonedx-json=/out/sbom.cyclonedx.json"

echo "Scanning $IMAGE_TAG for HIGH/CRITICAL vulnerabilities"
set -o pipefail
docker run --rm \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  --volume /var/run/docker.sock:/var/run/docker.sock:ro \
  --volume "$TRIVY_CACHE_VOLUME:/root/.cache/trivy" \
  "$TRIVY_IMAGE" \
  image \
  --timeout 15m \
  --scanners vuln \
  --ignore-unfixed \
  --exit-code 1 \
  --severity HIGH,CRITICAL \
  --table-mode detailed \
  --no-progress \
  "$IMAGE_TAG" | tee "$OUTPUT_DIR/trivy-report.txt"

echo "Clean: no unaddressed HIGH/CRITICAL findings. SBOM: $OUTPUT_DIR/sbom.cyclonedx.json, report: $OUTPUT_DIR/trivy-report.txt"
