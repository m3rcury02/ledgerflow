#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
ENV_FILE=${LEDGERFLOW_ENV_FILE:-"$ROOT_DIR/.env"}

if [[ ! -f "$ENV_FILE" ]]; then
  ENV_FILE="$ROOT_DIR/.env.example"
fi

echo "Deleting all LedgerFlow local infrastructure containers and named volumes."
docker compose \
  --env-file "$ENV_FILE" \
  --file "$ROOT_DIR/compose.yaml" \
  down \
  --volumes \
  --remove-orphans

LEDGERFLOW_ENV_FILE="$ENV_FILE" "$ROOT_DIR/scripts/dev-up"
