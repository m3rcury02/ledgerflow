#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
ENV_FILE=${LEDGERFLOW_ENV_FILE:-"$ROOT_DIR/.env"}

if [[ ! -f "$ENV_FILE" ]]; then
  ENV_FILE="$ROOT_DIR/.env.example"
  echo "Using non-secret defaults from .env.example; create an ignored .env to override them."
fi

compose() {
  docker compose --env-file "$ENV_FILE" --file "$ROOT_DIR/compose.yaml" "$@"
}

compose config --quiet
compose up --detach --wait --wait-timeout "${DEV_START_TIMEOUT_SECONDS:-300}"
"$ROOT_DIR/scripts/dev-status"
