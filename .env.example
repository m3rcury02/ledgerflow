# Local development only. These values are placeholders, not production secrets.
COMPOSE_PROJECT_NAME=ledgerflow-local

POSTGRES_PORT=5432
POSTGRES_DB=ledgerflow
POSTGRES_USER=ledgerflow
POSTGRES_PASSWORD=change-me-local-postgres

KAFKA_PORT=9092
VALKEY_PORT=6379

KEYCLOAK_PORT=8081
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-local-keycloak-db
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-local-keycloak-admin

# Application-local overrides (Compose ignores these). Port 8081 is already Keycloak on the host.
LEDGERFLOW_MANAGEMENT_PORT=8082
LEDGERFLOW_HEALTH_PROBE_CACHE_TTL=2s
LEDGERFLOW_DEPLOYMENT_ENVIRONMENT=local
LEDGERFLOW_TRACE_SAMPLING_PROBABILITY=1.0
LEDGERFLOW_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
LEDGERFLOW_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-grafana-admin
TEMPO_PORT=3200
LOKI_PORT=3100
