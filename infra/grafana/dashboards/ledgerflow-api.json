{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/orders.*\"}[5m]))", "legendFormat": "requests"}],
      "title": "Order API request rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/orders.*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/orders.*\"}[5m])), 0.001)", "legendFormat": "system errors"}],
      "title": "Order API system failure ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{uri=\"/api/v1/orders\",method=\"POST\"}[5m])))", "legendFormat": "p95"}],
      "title": "Create order latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 4,
      "targets": [{"expr": "sum by (outcome) (rate(ledgerflow_orders_workflow_total[5m]))", "legendFormat": "{{outcome}}"}],
      "title": "Order workflow outcomes",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": ["ledgerflow", "api"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "utc",
  "title": "LedgerFlow — API",
  "uid": "ledgerflow-api",
  "version": 1
}
